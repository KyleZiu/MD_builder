# MarkItDown Web Converter 环境配置

# Fernet 加密密钥（用于加密 API Key）
# 首次运行时自动生成，如需重置请手动设置
FERNET_KEY=

# 数据库配置
# 使用 SQLite（默认）或 PostgreSQL
# PostgreSQL: DATABASE_URL=postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=sqlite+aiosqlite:///./app.db

# 最大文件大小（字节）
MAX_FILE_SIZE=52428800

# CORS 允许的来源（多个用逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
